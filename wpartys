<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>VibeCoder Cinematic Party (Toast Edition)</title>
    <script src="https://unpkg.com/peerjs@1.5.2/dist/peerjs.min.js"></script>
    <style>
        :root {
            --bg-color: #000000; --surface-color: #111827; --text-main: #f9fafb; --text-muted: #9ca3af;
            --primary: #8b5cf6; --success: #10b981; --error: #ef4444;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
        body, html { height: 100%; width: 100%; overflow: hidden; background-color: var(--bg-color); color: var(--text-main); }

        /* --- 1. KURULUM (LOBİ) EKRANI --- */
        #setup-screen {
            position: fixed; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center;
            background: linear-gradient(135deg, #0f172a, #000000); z-index: 100; padding: 2rem;
        }
        .setup-card { background: rgba(255,255,255,0.05); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.1); border-radius: 1.5rem; padding: 2.5rem 2rem; width: 100%; max-width: 400px; display: flex; flex-direction: column; gap: 1.25rem; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5); }
        .title { font-size: 1.75rem; font-weight: 800; text-align: center; color: white; margin-bottom: 0.5rem; }
        
        .btn { width: 100%; padding: 1rem; border: none; border-radius: 1rem; background: var(--primary); color: white; font-weight: bold; font-size: 1rem; cursor: pointer; transition: 0.2s; }
        .btn:active { transform: scale(0.98); }
        .btn-success { background: var(--success); }
        
        .input-style { width: 100%; padding: 1rem; border: 1px solid rgba(255,255,255,0.2); border-radius: 1rem; background: rgba(0,0,0,0.3); color: white; font-size: 1.1rem; outline: none; text-align: center; }
        .input-style:focus { border-color: var(--primary); }
        
        #code-display { font-family: monospace; font-size: 3rem; font-weight: bold; color: var(--primary); text-align: center; letter-spacing: 8px; margin: 1rem 0; }
        #setup-log { text-align: center; color: var(--error); font-size: 0.9rem; height: 1rem; }

        /* --- 2. SİNEMA EKRANI (TAM EKRAN IFRAME) --- */
        #cinema-screen { display: none; width: 100%; height: 100%; position: relative; }
        
        #shared-iframe { width: 100%; height: 100%; border: none; background: #000; }
        
        /* Iframe üzerine tıklamaları (geçici olarak) kilitlemek için görünmez kalkan */
        #iframe-shield { position: absolute; inset: 0; z-index: 5; display: none; background: transparent; }

        /* --- 3. TOAST SOHBET SİSTEMİ (Ekranda süzülen mesajlar) --- */
        #toast-container {
            position: absolute; top: 15%; left: 5%; right: 5%; bottom: 20%;
            pointer-events: none; /* Tıklamalar iframe'e geçsin diye */
            display: flex; flex-direction: column; justify-content: flex-end; gap: 0.5rem; z-index: 50;
            overflow: hidden;
        }

        .toast-msg {
            max-width: 85%; padding: 0.75rem 1.25rem; border-radius: 1.5rem; font-size: 1rem; font-weight: 500;
            line-height: 1.4; color: white; backdrop-filter: blur(5px); box-shadow: 0 4px 15px rgba(0,0,0,0.5);
            animation: slideIn 0.3s ease-out forwards;
            pointer-events: auto; /* Baloncuğa dokunulabilsin diye */
        }
        .toast-msg.me { align-self: flex-end; background: rgba(139, 92, 246, 0.85); border-bottom-right-radius: 0.25rem; }
        .toast-msg.other { align-self: flex-start; background: rgba(55, 65, 81, 0.85); border-bottom-left-radius: 0.25rem; }
        .toast-msg.system { align-self: center; background: rgba(0, 0, 0, 0.6); font-size: 0.85rem; padding: 0.5rem 1rem; border-radius: 2rem; color: var(--success);}
        
        .toast-msg.fade-out { animation: fadeOut 0.5s ease-in forwards; }

        @keyframes slideIn { from { opacity: 0; transform: translateY(20px) scale(0.9); } to { opacity: 1; transform: translateY(0) scale(1); } }
        @keyframes fadeOut { from { opacity: 1; transform: translateY(0); } to { opacity: 0; transform: translateY(-10px); } }

        /* --- 4. ALT KONTROL BAR (Host URL girme & Sohbet Yazma) --- */
        #control-bar {
            position: absolute; bottom: 0; left: 0; right: 0; z-index: 60;
            background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0) 100%);
            padding: 2rem 1rem 1rem 1rem; padding-bottom: max(1rem, env(safe-area-inset-bottom));
            display: flex; flex-direction: column; gap: 0.75rem;
            transition: transform 0.3s ease;
        }

        .control-row { display: flex; gap: 0.5rem; width: 100%; max-width: 600px; margin: 0 auto; }
        
        .bar-input { flex: 1; padding: 0.85rem 1.25rem; border: none; border-radius: 2rem; background: rgba(255,255,255,0.15); color: white; font-size: 1rem; outline: none; backdrop-filter: blur(10px); }
        .bar-input::placeholder { color: rgba(255,255,255,0.6); }
        .bar-input:focus { background: rgba(255,255,255,0.25); }
        
        .bar-btn { padding: 0 1.5rem; border: none; border-radius: 2rem; background: var(--primary); color: white; font-weight: bold; cursor: pointer; }
        
        .hidden { display: none !important; }
    </style>
</head>
<body>

    <!-- LOBİ EKRANI -->
    <div id="setup-screen">
        <div class="title">🍿 Cinematic Party</div>
        <p style="color: var(--text-muted); margin-bottom: 2rem; text-align: center;">Tüm web sitelerini yansıt ve sohbet et.</p>
        
        <div id="card-start" class="setup-card">
            <button id="btn-create" class="btn">👑 Oda Kur (Host)</button>
            <div style="text-align: center; color: var(--text-muted); font-size: 0.9rem;">veya</div>
            <input type="text" id="join-code" class="input-style" placeholder="5 HANELİ KOD" maxlength="5" style="text-transform: uppercase; font-weight: bold; letter-spacing: 3px;">
            <button id="btn-join" class="btn btn-success">🔗 Katıl</button>
            <div id="setup-log"></div>
        </div>

        <div id="card-waiting" class="setup-card hidden">
            <p style="text-align: center; color: var(--text-muted);">Bağlantı Kodunuz:</p>
            <div id="code-display">...</div>
            <p style="text-align: center; color: var(--success); font-weight: bold;">İzleyici Bekleniyor...</p>
        </div>
    </div>

    <!-- SİNEMA EKRANI (TAM EKRAN) -->
    <div id="cinema-screen">
        
        <!-- Yansıtılan Site -->
        <iframe id="shared-iframe" allowfullscreen allow="autoplay; fullscreen"></iframe>
        
        <!-- Güvenlik Kalkanı (Sadece UI etkileşimleri sırasında Iframe tıklamalarını engeller) -->
        <div id="iframe-shield"></div>

        <!-- Yüzen Toast Mesajları -->
        <div id="toast-container"></div>

        <!-- Alt Kontrol Paneli -->
        <div id="control-bar">
            <!-- Sadece Host Görebilir: URL Çubuğu -->
            <div id="host-url-row" class="control-row hidden">
                <input type="text" id="host-url-input" class="bar-input" placeholder="Film sitesi, ok.ru, mp4 linki yapıştır...">
                <button id="btn-load-url" class="bar-btn">Aç</button>
            </div>
            
            <!-- Herkes Görebilir: Sohbet Çubuğu -->
            <form id="chat-form" class="control-row" onsubmit="sendChatMessage(event)">
                <input type="text" id="chat-input" class="bar-input" placeholder="Sohbet et (Kaybolan mesajlar)..." autocomplete="off" required>
                <button type="submit" class="bar-btn">Gönder</button>
            </form>
        </div>
    </div>

    <script>
        /**
         * VibeCoder Cinematic Party v8.0
         * Mimari: URL Mirroring (Cobrowsing) + Ephemeral Toast Chat
         */

        const PREFIX = "vbc-cine-";
        let peer = null, conn = null, isHost = false;

        // DOM Elementleri
        const setupScreen = document.getElementById('setup-screen');
        const cinemaScreen = document.getElementById('cinema-screen');
        const cardStart = document.getElementById('card-start');
        const cardWaiting = document.getElementById('card-waiting');
        const codeDisplay = document.getElementById('code-display');
        const setupLog = document.getElementById('setup-log');
        
        const sharedIframe = document.getElementById('shared-iframe');
        const iframeShield = document.getElementById('iframe-shield');
        const toastContainer = document.getElementById('toast-container');
        
        const hostUrlRow = document.getElementById('host-url-row');
        const hostUrlInput = document.getElementById('host-url-input');
        const chatInput = document.getElementById('chat-input');

        // --- GÜVENLİK VE UX: KLAVYE & IFRAME ÇAKIŞMASI ---
        // Input'a tıklandığında Iframe'in focus çalmamasını sağlamak için kalkanı açıyoruz
        chatInput.addEventListener('focus', () => iframeShield.style.display = 'block');
        chatInput.addEventListener('blur', () => iframeShield.style.display = 'none');
        hostUrlInput.addEventListener('focus', () => iframeShield.style.display = 'block');
        hostUrlInput.addEventListener('blur', () => iframeShield.style.display = 'none');

        // --- SİHİRLİ TOAST SİSTEMİ (Kaybolan Mesajlar) ---
        function showToast(text, type) {
            const toast = document.createElement('div');
            toast.className = `toast-msg ${type}`;
            toast.textContent = text;
            
            toastContainer.appendChild(toast);

            // 7 Saniye sonra eriyerek kaybolma efekti
            setTimeout(() => {
                toast.classList.add('fade-out');
                // Animasyon bitince DOM'dan tamamen sil
                setTimeout(() => toast.remove(), 500);
            }, 7000);
        }

        // --- P2P AĞ YÖNETİMİ ---
        function genCode() {
            const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789'; let res = '';
            for(let i=0; i<5; i++) res += chars.charAt(Math.floor(Math.random() * chars.length)); return res;
        }

        function loadMirroredUrl(url) {
            if(!url) return;
            // Ekrana basılan linki iframe'e yükle
            sharedIframe.src = url;
            if(isHost) {
                showToast("Sayfa yüklendi. Play tuşuna beraber basmak için sohbetten geri sayım yapın.", "system");
            } else {
                showToast("Host yeni bir sayfa açtı. Başlatmak için hazır olun.", "system");
            }
        }

        function startCinemaMode() {
            setupScreen.style.display = 'none';
            cinemaScreen.style.display = 'block';
            if(isHost) hostUrlRow.classList.remove('hidden');
        }

        function handleIncomingData(data) {
            if (data.type === 'chat') {
                showToast(data.text, 'other');
            } else if (data.type === 'sync-url') {
                loadMirroredUrl(data.url);
            }
        }

        // --- HOST İŞLEMLERİ ---
        document.getElementById('btn-create').addEventListener('click', () => {
            isHost = true;
            setupLog.textContent = "Bağlanılıyor...";
            const code = genCode();
            peer = new Peer(PREFIX + code);

            peer.on('open', () => {
                cardStart.classList.add('hidden');
                cardWaiting.classList.remove('hidden');
                codeDisplay.textContent = code;
            });

            peer.on('connection', (c) => {
                conn = c;
                startCinemaMode();
                showToast("İzleyici bağlandı! İzlemek istediğiniz sitenin linkini yapıştırın.", "system");
                conn.on('data', handleIncomingData);
            });
            peer.on('error', (err) => setupLog.textContent = "Hata: " + err.type);
        });

        // Host yeni URL yükler
        document.getElementById('btn-load-url').addEventListener('click', () => {
            let url = hostUrlInput.value.trim();
            if(!url) return;
            
            // Eğer URL'de http yoksa ekle (Iframe güvenliği için şarttır)
            if(!url.startsWith('http')) url = 'https://' + url;

            loadMirroredUrl(url);
            if(conn && conn.open) {
                conn.send({ type: 'sync-url', url: url });
            }
            hostUrlInput.value = '';
            hostUrlInput.blur(); // Klavyeyi kapat
        });

        // --- İZLEYİCİ İŞLEMLERİ ---
        document.getElementById('btn-join').addEventListener('click', () => {
            const code = document.getElementById('join-code').value.trim().toUpperCase();
            if(code.length !== 5) { setupLog.textContent = "Lütfen 5 haneli kodu girin."; return; }
            
            isHost = false;
            setupLog.textContent = "Bağlanıyor...";
            peer = new Peer();

            peer.on('open', () => {
                conn = peer.connect(PREFIX + code);
                conn.on('open', () => {
                    startCinemaMode();
                    showToast("Bağlantı kuruldu! Host'un sayfa açması bekleniyor.", "system");
                    conn.on('data', handleIncomingData);
                });
                conn.on('error', () => showToast("Bağlantı koptu.", "system"));
            });
            peer.on('error', () => setupLog.textContent = "Kod hatalı veya oda kapalı.");
        });

        // --- TOAST SOHBET GÖNDERME ---
        window.sendChatMessage = function(e) {
            e.preventDefault();
            const text = chatInput.value.trim();
            if (!text || !conn || !conn.open) return;
            
            // Kendimize göster
            showToast(text, 'me');
            
            // Karşıya gönder
            conn.send({ type: 'chat', text: text });
            
            chatInput.value = '';
            // Mobilde klavyeyi açık tutmak isteyenler için odağı bırakmıyoruz,
            // ama iframe ile etkileşime geçmek için ekrana bir kez dokunmaları gerekecek.
        };

    </script>
</body>
</html>
